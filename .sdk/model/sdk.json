    "kit": {
      "info": {
        "contact": {
          "url": "https://ip-api.com/docs/api:json"
        },
        "description": "This API allows users to retrieve geolocation information from an IP address or domain name. It provides details such as country, city, region, latitude, longitude, and more in a JSON format without requiring an API key.",
        "servers": [
          {
            "description": "Main API server (HTTP only for free tier)",
            "url": "http://ip-api.com"
          }
        ],
        "termsOfService": "https://ip-api.com",
        "title": "IP Geolocation API",
        "version": "1.0.0",
        "tagline": "Look up geolocation and network details for any IP address or domain over plain HTTP",
        "homepage": "http://ip-api.com",
        "docs_url": "http://ip-api.com/docs",
        "license_short": "Free for non-commercial use; commercial use requires a paid pro subscription.",
        "license_md": "- Free tier is for non-commercial use only.\n- No API key or registration required for the free endpoint.\n- Commercial use, SSL access, and unlimited queries require the paid pro service.\n- Operator commits that the free API schema will not change.",
        "about_md": "[ip-api.com](http://ip-api.com) is an IP geolocation service that has operated since 2012, resolving IPv4/IPv6 addresses and domain names to location and network metadata. The operator reports handling more than a billion requests per day.\n\nWhat you get from the API:\n\n- Location fields such as `country`, `countryCode`, `region`, `regionName`, `city`, `lat`, `lon`, and `timezone`.\n- Network fields including `isp`, `org`, and AS information.\n- Flags indicating whether the address is associated with mobile, proxy, or hosting networks.\n- A `fields` query parameter to restrict the response to only the values you need.\n\nThe free JSON endpoint lives at `http://ip-api.com/json/{query}` and is accessed over plain HTTP with no key. Requests are limited to 45 per minute per client IP; over-limit calls return HTTP 429, and each response includes `X-Rl` (requests remaining) and `X-Ttl` (seconds until reset) headers. Batch and DNS endpoints are also available, and HTTPS plus higher quotas are offered through the paid pro tier.",
        "entity_desc": {
          "json": "Geolocation lookup for an IP address or domain, returned as JSON from `/json/{query}` with optional `fields` filtering."
        },
        "auth": false
      },
